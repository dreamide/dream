{
  "name": "dream",
  "productName": "Dream",
  "description": "Dream is a desktop IDE for working with AI coding agents.",
  "version": "0.2.1",
  "private": true,
  "scripts": {
    "dev": "pnpm electron:dev",
    "build": "pnpm package:dir",
    "vite:dev": "vite --host 127.0.0.1 --port 3210 --strictPort",
    "vite:build": "vite build",
    "electron:dev": "node scripts/prepare-electron-dev-app.mjs && cross-env NODE_ENV=development ELECTRON_DISABLE_SECURITY_WARNINGS=true electron electron/main.js",
    "db:generate": "drizzle-kit generate",
    "import:codex-chats": "node scripts/import-codex-chats.mjs",
    "postinstall": "node scripts/fix-node-pty-permissions.mjs && node scripts/prepare-electron-dev-app.mjs",
    "start": "node scripts/prepare-electron-dev-app.mjs && cross-env NODE_ENV=production electron electron/main.js",
    "package": "pnpm package:dir",
    "package:dir": "pnpm vite:build && electron-builder --dir",
    "package:mac": "pnpm vite:build && electron-builder --mac",
    "package:win": "pnpm vite:build && cross-env HOME=.electron-home electron-builder --win",
    "package:win:signed": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/package-win-signed.ps1",
    "package:linux": "pnpm vite:build && cross-env HOME=.electron-home electron-builder --linux",
    "dist": "pnpm package",
    "lint": "biome check .",
    "typecheck": "tsc --noEmit",
    "format": "biome format --write ."
  },
  "dependencies": {
    "@hono/node-server": "^2.0.5",
    "@opencode-ai/sdk": "1.15.5",
    "@pierre/diffs": "^1.2.10",
    "ai": "^6.0.206",
    "ai-sdk-provider-claude-code": "^3.5.0",
    "ccount": "2.0.1",
    "character-entities-html4": "2.1.0",
    "character-entities-legacy": "3.0.0",
    "comma-separated-tokens": "2.0.3",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "electron-updater": "^6.8.9",
    "get-port": "^7.2.0",
    "hast-util-to-html": "9.0.5",
    "hast-util-whitespace": "3.0.0",
    "hono": "^4.12.25",
    "html-void-elements": "3.0.0",
    "node-pty": "^1.1.0",
    "property-information": "7.1.0",
    "sirv": "^3.0.2",
    "space-separated-tokens": "2.0.2",
    "stringify-entities": "4.0.4",
    "zod": "^4.4.3",
    "zwitch": "2.0.4"
  },
  "devDependencies": {
    "@ai-sdk/gateway": "^3.0.132",
    "@ai-sdk/provider": "3.0.8",
    "@ai-sdk/provider-utils": "4.0.23",
    "@ai-sdk/react": "^3.0.208",
    "@base-ui/react": "^1.5.0",
    "@biomejs/biome": "2.4.13",
    "@opentelemetry/api": "1.9.0",
    "@pierre/trees": "1.0.0-beta.3",
    "@streamdown/cjk": "^1.0.3",
    "@streamdown/code": "^1.1.1",
    "@streamdown/math": "^1.0.2",
    "@streamdown/mermaid": "^1.0.2",
    "@tailwindcss/postcss": "^4.3.1",
    "@types/node": "^25.9.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19",
    "@vercel/oidc": "3.2.0",
    "@vitejs/plugin-react": "^6.0.2",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/xterm": "^6.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "cross-env": "^10.1.0",
    "date-fns": "^4.4.0",
    "drizzle-kit": "^0.31.10",
    "electron": "^41.7.2",
    "electron-builder": "^26.15.3",
    "lucide-react": "^1.18.0",
    "material-icon-theme": "^5.35.0",
    "motion": "^12.40.0",
    "nanoid": "^5.1.11",
    "next-themes": "^0.4.6",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "shadcn": "^4.11.0",
    "shiki": "^4.2.0",
    "streamdown": "^2.5.0",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.1",
    "tokenlens": "^1.3.1",
    "tsx": "^4.22.4",
    "tw-animate-css": "^1.4.0",
    "typescript": "^6.0.3",
    "use-stick-to-bottom": "^1.1.6",
    "vite": "^8.0.16",
    "zustand": "^5.0.14"
  },
  "main": "electron/main.js",
  "build": {
    "appId": "ai.dreamdream.dream",
    "productName": "Dream",
    "executableName": "Dream",
    "npmRebuild": false,
    "directories": {
      "output": "release"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "dreamide",
        "repo": "dream"
      }
    ],
    "afterPack": "scripts/prune-packaged-app.cjs",
    "files": [
      "electron/**/*",
      "dist/**/*",
      "public/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "public/icon.ico",
        "to": "icon.ico"
      },
      {
        "from": "public/icon.png",
        "to": "icon.png"
      }
    ],
    "icon": "public/icon.png",
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "artifactName": "${productName}-${version}-${arch}.${ext}",
      "category": "public.app-category.developer-tools",
      "hardenedRuntime": true,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist",
      "signIgnore": [
        "Contents/Resources/app\\.asar$",
        "Contents/Resources/[^/]+\\.icns$",
        "Contents/Frameworks/Electron Framework\\.framework/(Versions/[^/]+/)?Resources/.*",
        "Contents/Resources/app\\.asar\\.unpacked/.*\\.wasm$",
        "Contents/Resources/app\\.asar\\.unpacked/node_modules/@anthropic-ai/claude-agent-sdk/vendor/.*/(arm64-win32|x64-win32|x64-linux|arm64-linux)/",
        "Contents/Resources/app\\.asar\\.unpacked/node_modules/node-pty/prebuilds/win32-",
        "Contents/Resources/app\\.asar\\.unpacked/node_modules/node-pty/deps/winpty/"
      ],
      "singleArchFiles": "node_modules/**/*darwin*/**",
      "x64ArchFiles": "Contents/Resources/app.asar.unpacked/node_modules/**/*darwin*/**"
    },
    "win": {
      "icon": "public/icon.ico",
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "artifactName": "${productName}-${version}-${arch}-setup.${ext}"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb",
        "rpm"
      ],
      "maintainer": "Dream <support@dreamide.ai>",
      "artifactName": "${productName}-${version}-${arch}.${ext}"
    }
  },
  "type": "module"
}
