{
  "name": "dream",
  "productName": "Dream",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "pnpm electron:dev",
    "build": "pnpm package:dir",
    "vite:dev": "vite --host 127.0.0.1 --port 3210 --strictPort",
    "vite:build": "vite build",
    "electron:dev": "node scripts/prepare-electron-dev-app.mjs && cross-env NODE_ENV=development ELECTRON_DISABLE_SECURITY_WARNINGS=true electron electron/main.js",
    "db:generate": "drizzle-kit generate",
    "import:codex-chats": "node scripts/import-codex-chats.mjs",
    "postinstall": "node scripts/fix-node-pty-permissions.mjs && node scripts/prepare-electron-dev-app.mjs",
    "start": "node scripts/prepare-electron-dev-app.mjs && cross-env NODE_ENV=production electron electron/main.js",
    "package": "pnpm package:dir",
    "package:dir": "pnpm vite:build && electron-builder --dir",
    "package:mac": "pnpm vite:build && electron-builder --mac",
    "package:win": "pnpm vite:build && cross-env HOME=.electron-home electron-builder --win",
    "package:win:signed": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/package-win-signed.ps1",
    "package:linux": "pnpm vite:build && cross-env HOME=.electron-home electron-builder --linux",
    "dist": "pnpm package",
    "lint": "biome check .",
    "typecheck": "tsc --noEmit",
    "format": "biome format --write ."
  },
  "dependencies": {
    "@ai-sdk/gateway": "^3.0.121",
    "@ai-sdk/provider": "3.0.8",
    "@ai-sdk/provider-utils": "4.0.23",
    "@ai-sdk/react": "^3.0.195",
    "@base-ui/react": "^1.5.0",
    "@hono/node-server": "^2.0.4",
    "@opencode-ai/sdk": "1.15.5",
    "@opentelemetry/api": "1.9.0",
    "@pierre/diffs": "^1.2.4",
    "@pierre/trees": "1.0.0-beta.3",
    "@streamdown/cjk": "^1.0.3",
    "@streamdown/code": "^1.1.1",
    "@streamdown/math": "^1.0.2",
    "@streamdown/mermaid": "^1.0.2",
    "@vercel/oidc": "3.2.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/xterm": "^6.0.0",
    "ai": "^6.0.193",
    "ai-sdk-provider-claude-code": "^3.4.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.3.0",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "get-port": "^7.2.0",
    "hono": "^4.12.23",
    "lucide-react": "^1.17.0",
    "material-icon-theme": "^5.35.0",
    "motion": "^12.40.0",
    "nanoid": "^5.1.11",
    "next-themes": "^0.4.6",
    "node-pty": "^1.1.0",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "shiki": "^4.1.0",
    "sirv": "^3.0.2",
    "streamdown": "^2.5.0",
    "tailwind-merge": "^3.6.0",
    "tokenlens": "^1.3.1",
    "use-stick-to-bottom": "^1.1.4",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.13",
    "@tailwindcss/postcss": "^4.3.0",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.2",
    "cross-env": "^10.1.0",
    "drizzle-kit": "^0.31.10",
    "electron": "^41.7.1",
    "electron-builder": "^26.8.1",
    "shadcn": "^4.8.3",
    "tailwindcss": "^4.3.0",
    "tsx": "^4.22.3",
    "tw-animate-css": "^1.4.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.14"
  },
  "main": "electron/main.js",
  "build": {
    "appId": "ai.dreamdream.dream",
    "productName": "Dream",
    "executableName": "Dream",
    "npmRebuild": false,
    "directories": {
      "output": "release"
    },
    "files": [
      "electron/**/*",
      "dist/**/*",
      "public/**/*",
      "package.json",
      "node_modules/**/*",
      {
        "from": "node_modules/.pnpm/node_modules",
        "to": "node_modules",
        "filter": [
          "**/*"
        ]
      }
    ],
    "icon": "public/icon.png",
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.developer-tools",
      "hardenedRuntime": true,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist"
    },
    "win": {
      "target": [
        "nsis"
      ]
    },
    "linux": {
      "target": [
        "AppImage"
      ]
    }
  },
  "type": "module"
}
