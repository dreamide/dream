{
  "name": "dream",
  "productName": "Dream",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "pnpm dev:electron",
    "dev:vite": "vite --host 127.0.0.1 --port 3210 --strictPort",
    "dev:electron": "cross-env NODE_ENV=development ELECTRON_DISABLE_SECURITY_WARNINGS=true electron electron/main.js",
    "import:codex-chats": "node scripts/import-codex-chats.mjs",
    "build": "vite build",
    "start": "cross-env NODE_ENV=production electron electron/main.js",
    "dist": "pnpm build && electron-builder",
    "lint": "biome check .",
    "typecheck": "tsc --noEmit",
    "format": "biome format --write ."
  },
  "dependencies": {
    "@ai-sdk/react": "^3.0.170",
    "@base-ui/react": "^1.4.1",
    "@hono/node-server": "^2.0.0",
    "@pierre/diffs": "^1.1.19",
    "@streamdown/cjk": "^1.0.3",
    "@streamdown/code": "^1.1.1",
    "@streamdown/math": "^1.0.2",
    "@streamdown/mermaid": "^1.0.2",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/xterm": "^6.0.0",
    "ai": "^6.0.168",
    "ai-sdk-provider-claude-code": "^3.4.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "hono": "^4.12.15",
    "lucide-react": "^1.11.0",
    "motion": "^12.38.0",
    "nanoid": "^5.1.9",
    "next-themes": "^0.4.6",
    "node-pty": "^1.1.0",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "shiki": "^4.0.2",
    "sirv": "^3.0.2",
    "streamdown": "^2.5.0",
    "tailwind-merge": "^3.5.0",
    "tokenlens": "^1.3.1",
    "use-stick-to-bottom": "^1.1.3",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.13",
    "@tailwindcss/postcss": "^4.2.4",
    "@types/node": "^25.6.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.1",
    "cross-env": "^10.1.0",
    "electron": "^41.3.0",
    "electron-builder": "^26.8.1",
    "shadcn": "^4.4.0",
    "tailwindcss": "^4.2.4",
    "tsx": "^4.21.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.10"
  },
  "main": "electron/main.js",
  "build": {
    "appId": "com.mikecao.dream",
    "productName": "Dream",
    "executableName": "Dream",
    "directories": {
      "output": "release"
    },
    "files": [
      "electron/**/*",
      "dist/**/*",
      "public/**/*",
      "package.json",
      "node_modules/**/*"
    ],
    "icon": "public/icon.png",
    "mac": {
      "icon": "build/icon.icns",
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.developer-tools",
      "hardenedRuntime": true,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist"
    },
    "win": {
      "target": [
        "nsis"
      ]
    },
    "linux": {
      "target": [
        "AppImage"
      ]
    },
    "publish": "never"
  },
  "type": "module"
}
